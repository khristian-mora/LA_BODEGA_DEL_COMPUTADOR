# Server Configuration
PORT=3000

# Authentication
# Generate a secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace_this_with_a_secure_random_string

# Database (Optional - defaults to SQLite)
# DB_HOST=localhost
# DB_USER=root
# DB_PASSWORD=password
# DB_NAME=la_bodega

# Email Notifications (SMTP Configuration)
# For Hostinger: Use your Hostinger email SMTP settings from cPanel
# For Gmail: smtp.gmail.com, port 465, enable "Less secure app access" or use App Password
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=notificaciones@tudominio.com
SMTP_PASS=tu_contraseña_smtp
SMTP_FROM=La Bodega del Computador <notificaciones@tudominio.com>
BUSINESS_PHONE=+57 300 123 4567

# NOTE: Cloudinary removed - photos now stored locally in server/uploads/
