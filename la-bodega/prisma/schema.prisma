generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  CLIENTE
  CAJERA
  ADMIN
  TECNICO
  GERENTE
  VENDEDOR
}

enum ProductStatus {
  ACTIVO
  INACTIVO
  BORRADOR
}

enum OrderStatus {
  PENDIENTE
  CONFIRMADO
  ENVIADO
  ENTREGADO
  CANCELADO
}

enum PaymentStatus {
  PENDIENTE
  PAGADO
  FALLIDO
  REEMBOLSADO
}

enum PaymentMethod {
  TARJETA
  TRANSFERENCIA
  CONTRAENTREGA
}

enum ServiceStatus {
  RECIBIDO
  EN_DIAGNOSTICO
  PENDIENTE_APROBACION
  EN_REPARACION
  LISTO_PARA_ENTREGA
  ENTREGADO
  SIN_REPARACION
}

enum EmailStatus {
  ENVIADO
  FALLIDO
  PENDIENTE
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum TicketStatus {
  RECEIVED
  DIAGNOSED
  REPAIRING
  READY
  DELIVERED
  CANCELLED
}

enum WarrantyStatus {
  ACTIVE
  EXPIRED
  VOID
  CLAIMED
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  TERMINATED
  ON_LEAVE
}

enum ReturnStatus {
  PENDING
  APPROVED
  REJECTED
  REFUNDED
  COMPLETED
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

// ==================== USUARIOS Y AUTENTICACIÓN ====================

model User {
  id                Int       @id @default(autoincrement())
  name              String
  email             String    @unique
  passwordHash      String?   @map("password_hash")
  phone             String?
  role              Role      @default(CLIENTE)
  status            UserStatus @default(ACTIVE)
  emailVerified     DateTime? @map("email_verified")
  image             String?
  resetToken        String?   @map("reset_token")
  resetTokenExpiry  DateTime? @map("reset_token_expiry")
  twoFactorSecret   String?   @map("two_factor_secret")
  twoFactorEnabled  Boolean   @default(false) @map("two_factor_enabled")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  addresses         Address[]
  orders            Order[]
  cartItems         CartItem[]
  favorites         Favorite[]
  clientServiceOrders ServiceOrder[] @relation("ClientServiceOrders")
  serviceOrders     ServiceOrder[] @relation("TechnicianAssigned")
  passwordReset     PasswordReset?
  activityLogs      ActivityLog[]
  notifications     Notification[]
  technicianAppointments Appointment[] @relation("TechnicianAppointments")

  @@map("users")
}

model PasswordReset {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("password_resets")
}

// ==================== CRM Y CLIENTES ====================

model Customer {
  id            Int      @id @default(autoincrement())
  name          String
  email         String?
  phone         String?
  address       String?
  idNumber      String?  @map("id_number")
  customerType  String   @default("Regular") @map("customer_type")
  notes         String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  appointments  Appointment[]
  warranties    Warranty[]
  returns       Return[]
  orders        Order[]

  @@map("customers")
}

model Address {
  id          Int      @id @default(autoincrement())
  userId      Int      @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label       String
  street      String
  city        String
  department  String   @map("department")
  zip         String?
  country     String   @default("Colombia")
  isDefault   Boolean  @default(false) @map("is_default")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  orders      Order[]

  @@map("addresses")
}

// ==================== INVENTARIO ====================

model Category {
  id        Int       @id @default(autoincrement())
  name      String
  slug      String    @unique
  parentId  Int?      @map("parent_id")
  parent    Category? @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryHierarchy")
  products  Product[]
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@map("categories")
}

model Brand {
  id        Int       @id @default(autoincrement())
  name      String
  slug      String    @unique
  logoUrl   String?   @map("logo_url")
  products  Product[]
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@map("brands")
}

model Supplier {
  id        Int       @id @default(autoincrement())
  name      String
  contact   String?
  email     String?
  phone     String?
  category  String?
  notes     String?
  status    String    @default("active")
  products  Product[]
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@map("suppliers")
}

model Product {
  id              Int           @id @default(autoincrement())
  name            String
  slug            String        @unique
  description     String?
  categoryId      Int?          @map("category_id")
  category        Category?     @relation(fields: [categoryId], references: [id])
  brandId         Int?          @map("brand_id")
  brand           Brand?        @relation(fields: [brandId], references: [id])
  supplierId      Int?          @map("supplier_id")
  supplier        Supplier?     @relation(fields: [supplierId], references: [id])
  price           Float
  salePrice       Float?        @map("sale_price")
  saleEndsAt      DateTime?     @map("sale_ends_at")
  stock           Int           @default(0)
  stockMinimo     Int           @default(2) @map("stock_minimo")
  stockMaximo     Int           @default(20) @map("stock_maximo")
  sku             String?       @unique
  images          Json?
  specsJson       Json?         @map("specs_json")
  status          ProductStatus @default(ACTIVO)
  isNew           Boolean       @default(true) @map("is_new")
  featured        Boolean       @default(false)
  builderCategory String?       @map("builder_category")
  supplierEmail   String?       @map("supplier_email")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  cartItems       CartItem[]
  orderItems      OrderItem[]
  favorites       Favorite[]
  serviceOrders   ServiceOrder[]
  warrantyClaims  WarrantyClaim[]

  @@map("products")
}

model Favorite {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId Int      @map("product_id")
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, productId])
  @@map("favorites")
}

// ==================== CARRITO Y VENTAS ====================

model CartItem {
  id        Int      @id @default(autoincrement())
  userId    Int?     @map("user_id")
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionId String?  @map("session_id")
  productId Int      @map("product_id")
  product   Product  @relation(fields: [productId], references: [id])
  quantity  Int      @default(1)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, productId])
  @@unique([sessionId, productId])
  @@map("cart_items")
}

model CartDraft {
  id        Int      @id @default(autoincrement())
  email     String?
  phone     String?
  name      String?
  cartData  String?  @map("cart_data")
  updatedAt String?  @map("updated_at")

  @@map("cart_drafts")
}

model Coupon {
  id          Int      @id @default(autoincrement())
  code        String   @unique
  type        String   @default("percent")
  value       Float
  minPurchase Float?   @map("min_purchase")
  maxUses     Int?     @map("max_uses")
  usedCount   Int      @default(0) @map("used_count")
  active      Boolean  @default(true)
  expiresAt   DateTime? @map("expires_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  orders      Order[]

  @@map("coupons")
}

model Order {
  id            Int           @id @default(autoincrement())
  orderNumber   String        @unique @map("order_number")
  userId        Int?          @map("user_id")
  user          User?         @relation(fields: [userId], references: [id])
  customerId    Int?          @map("customer_id")
  customer      Customer?     @relation(fields: [customerId], references: [id])
  addressId     Int?          @map("address_id")
  address       Address?      @relation(fields: [addressId], references: [id])
  status        OrderStatus   @default(PENDIENTE)
  subtotal      Float
  discount      Float         @default(0)
  tax           Float         @default(0)
  total         Float
  paymentMethod PaymentMethod @map("payment_method")
  paymentStatus PaymentStatus @default(PENDIENTE) @map("payment_status")
  paymentId     String?       @map("payment_id")
  couponId      Int?          @map("coupon_id")
  coupon        Coupon?       @relation(fields: [couponId], references: [id])
  notes         String?
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  items         OrderItem[]

  @@map("orders")
}

model OrderItem {
  id         Int     @id @default(autoincrement())
  orderId    Int     @map("order_id")
  order      Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId  Int     @map("product_id")
  product    Product @relation(fields: [productId], references: [id])
  quantity   Int
  unitPrice  Float   @map("unit_price")

  @@map("order_items")
}

// ==================== TICKETS (REPARACIONES DEL BACKEND) ====================

model Ticket {
  id                Int           @id @default(autoincrement())
  clientName        String?       @map("client_name")
  clientPhone       String?       @map("client_phone")
  deviceType        String?       @map("device_type")
  brand             String?
  model             String?
  serial            String?
  issueDescription  String?       @map("issue_description")
  status            String        @default("RECEIVED")
  diagnosis         String?
  estimatedCost     Int?          @map("estimated_cost")
  technicianNotes   String?       @map("technician_notes")
  photosIntake      String?       @map("photos_intake")
  quoteItems        String?       @map("quote_items")
  approvedByClient  Boolean       @default(false) @map("approved_by_client")
  findings          String?
  recommendations   String?
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  @@map("tickets")
}

// ==================== REPARACIONES (SERVICE ORDERS) ====================

model ServiceOrder {
  id                Int           @id @default(autoincrement())
  orderNumber       String        @unique @map("order_number")
  userId            Int?          @map("user_id")
  user              User?         @relation("ClientServiceOrders", fields: [userId], references: [id])
  customerName      String        @map("customer_name")
  customerIdNumber  String?       @map("customer_id_number")
  customerEmail     String        @map("customer_email")
  customerPhone     String        @map("customer_phone")
  deviceType        String        @map("device_type")
  brand             String
  model             String
  serial            String?
  reportedIssue     String        @map("reported_issue")
  physicalCondition String?       @map("physical_condition")
  accessories       String?
  password          String?
  technicianId      Int?          @map("technician_id")
  technician        User?         @relation("TechnicianAssigned", fields: [technicianId], references: [id])
  productId         Int?          @map("product_id")
  product           Product?      @relation(fields: [productId], references: [id])
  status            ServiceStatus @default(RECIBIDO)
  diagnosis         String?
  budgetJson        Json?         @map("budget_json")
  budgetApproved    Boolean?      @map("budget_approved")
  budgetApprovedAt  DateTime?     @map("budget_approved_at")
  notes             String?
  receivedAt        DateTime      @default(now()) @map("received_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  photos            ServicePhoto[]
  statusHistory     ServiceStatusHistory[]

  @@map("service_orders")
}

model ServicePhoto {
  id              Int          @id @default(autoincrement())
  serviceOrderId  Int          @map("service_order_id")
  serviceOrder    ServiceOrder @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)
  url             String
  stage           String
  description     String?
  uploadedAt      DateTime     @default(now()) @map("uploaded_at")

  @@map("service_photos")
}

model ServiceStatusHistory {
  id              Int          @id @default(autoincrement())
  serviceOrderId  Int          @map("service_order_id")
  serviceOrder    ServiceOrder @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)
  oldStatus       String?      @map("old_status")
  newStatus       String       @map("new_status")
  changedBy       String?      @map("changed_by")
  notes           String?
  changedAt       DateTime     @default(now()) @map("changed_at")

  @@map("service_status_history")
}

model TicketEvidence {
  id        Int      @id @default(autoincrement())
  ticketId  Int      @map("ticket_id")
  photoData String   @map("photo_data")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("ticket_evidence")
}

// ==================== GARANTÍAS ====================

model Warranty {
  id          Int           @id @default(autoincrement())
  ticketId    Int?          @map("ticket_id")
  orderId     Int?          @map("order_id")
  productId   Int?          @map("product_id")
  customerId  Int?          @map("customer_id")
  customer    Customer?     @relation(fields: [customerId], references: [id])
  startDate   DateTime      @map("start_date")
  endDate     DateTime      @map("end_date")
  terms       String?
  status      WarrantyStatus @default(ACTIVE)
  createdAt   DateTime      @default(now()) @map("created_at")

  claims      WarrantyClaim[]

  @@map("warranties")
}

model WarrantyClaim {
  id            Int       @id @default(autoincrement())
  warrantyId    Int       @map("warranty_id")
  warranty      Warranty  @relation(fields: [warrantyId], references: [id])
  productId     Int?      @map("product_id")
  product       Product?  @relation(fields: [productId], references: [id])
  claimDate     DateTime  @map("claim_date")
  description   String?
  resolution    String?
  resolvedDate  DateTime? @map("resolved_date")

  @@map("warranty_claims")
}

// ==================== NOTIFICACIONES ====================

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  user      User     @relation(fields: [userId], references: [id])
  type      String?
  title     String
  message   String
  link      String?
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("notifications")
}

// ==================== CITAS ====================

model Appointment {
  id             Int               @id @default(autoincrement())
  customerId     Int               @map("customer_id")
  customer       Customer          @relation(fields: [customerId], references: [id])
  technicianId   Int?              @map("technician_id")
  technician     User?             @relation("TechnicianAppointments", fields: [technicianId], references: [id])
  serviceType    String            @map("service_type")
  scheduledDate  DateTime          @map("scheduled_date")
  status         AppointmentStatus @default(PENDING)
  notes          String?
  createdAt      DateTime          @default(now()) @map("created_at")

  @@map("appointments")
}

// ==================== RECURSOS HUMANOS ====================

model Employee {
  id               Int           @id @default(autoincrement())
  employeeCode     String?       @unique @map("employee_code")
  name             String
  role             String?
  salary           Float?
  hireDate         DateTime?     @map("hire_date")
  status           EmployeeStatus @default(ACTIVE)
  phone            String?
  email            String?
  address          String?
  emergencyContact String?       @map("emergency_contact")
  notes            String?
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  @@map("employees")
}

// ==================== DEVOLUCIONES (RMA) ====================

model Return {
  id           Int          @id @default(autoincrement())
  rmaCode      String?      @unique @map("rma_code")
  orderId      Int?         @map("order_id")
  customerId   Int?         @map("customer_id")
  customer     Customer?    @relation(fields: [customerId], references: [id])
  customerName String?      @map("customer_name")
  product      String?
  reason       String?
  status       ReturnStatus @default(PENDING)
  resolution   String?
  refundAmount Float?       @map("refund_amount")
  createdAt    DateTime     @default(now()) @map("created_at")
  resolvedAt   DateTime?    @map("resolved_at")

  @@map("returns")
}

// ==================== FINANZAS ====================

model Expense {
  id            Int      @id @default(autoincrement())
  description   String
  amount        Float
  category      String?
  vendor        String?
  date          String?
  paymentMethod String?  @map("payment_method")
  notes         String?
  receiptUrl    String?  @map("receipt_url")
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("expenses")
}

// ==================== LOGS Y CONFIGURACIÓN ====================

model ActivityLog {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  user      User     @relation(fields: [userId], references: [id])
  action    String
  module    String?
  details   String?
  timestamp DateTime @default(now())

  @@map("user_activity_log")
}

model EmailLog {
  id          Int         @id @default(autoincrement())
  recipient   String
  subject     String
  template    String
  relatedId   String?     @map("related_id")
  relatedType String?     @map("related_type")
  status      EmailStatus @default(PENDIENTE)
  error       String?
  sentAt      DateTime?   @map("sent_at")
  createdAt   DateTime    @default(now()) @map("created_at")

  @@map("email_logs")
}

model SiteSettings {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("site_settings")
}

model Settings {
  key   String @id
  value String?

  @@map("settings")
}